* text=auto

# Keep source/data/docs normalized as LF in the repository.
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sh text eol=lf

# Windows-native script ergonomics in working trees.
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf
