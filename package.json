{
  "name": "rs3-progression-dashboard",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.5",
  "scripts": {
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter api dev",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "validate:runemetrics": "node scripts/validate-runemetrics.mjs",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  }
}
